{
    "name": "mason/laravel-captcha-kit",
    "description": "Unified captcha verification for Laravel — Google reCAPTCHA v2/v3, hCaptcha, and Cloudflare Turnstile behind one Manager-based API.",
    "license": "MIT",
    "keywords": [
        "laravel",
        "captcha",
        "recaptcha",
        "hcaptcha",
        "turnstile"
    ],
    "authors": [
        {
            "name": "Mason",
            "email": "mason0983838065@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^2.34|^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Mason\\Captcha\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mason\\Captcha\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mason\\Captcha\\CaptchaServiceProvider"
            ],
            "aliases": {
                "Captcha": "Mason\\Captcha\\Facades\\Captcha"
            }
        }
    },
    "scripts": {
        "test": "pest",
        "lint": "pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
